# Example env for docker compose / server. Copy to .env and fill values.
# Never commit real secrets.

DOCKER_IMAGE=ingluigii/btw-template-pdf:latest
API_PORT=8080
ASPNETCORE_ENVIRONMENT=Production

POSTGRES_USER=btw
POSTGRES_PASSWORD=change-me
